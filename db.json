  "spots": [
    {
      "id": "1",
      "name": "故宫",
      "nameEn": "Forbidden City",
      "image": "https://picsum.photos/600/350?random=1",
      "score": 9.6,
      "intro": "北京故宫，旧称紫禁城。位于北京中轴线的中心，是明清两个朝代的皇宫，占地面积72万平方米，建筑面积约15万平方米，是世界上现存规模最大、保存最为完整的木质结构的宫殿型建筑。",
      "address": "北京市东城区景山前街4号"
    },
    {
      "id": "2",
      "name": "长城",
      "nameEn": "The Great Wall",
      "image": "https://picsum.photos/600/350?random=2",
      "score": 9.7,
      "intro": "中国万里长城是古代的军事防御工程，是世界七大奇迹之一，1987年列入世界文化遗产。长城气势磅礴，横贯中国北方，象征着中华民族的坚韧与智慧。",
      "address": "北京市延庆区八达岭特区"
    },
    {
      "id": "3",
      "name": "颐和园",
      "nameEn": "Summer Palace",
      "image": "https://picsum.photos/600/350?random=3",
      "score": 9.3,
      "intro": "颐和园是保存最完整的一座皇家行宫御苑，被誉为“皇家园林博物馆”，是中国四大名园之一，以山水秀丽、建筑精美闻名世界。",
      "address": "北京市海淀区新建宫门路19号"
    },
    {
      "id": "4",
      "name": "天坛公园",
      "nameEn": "Temple of Heaven",
      "image": "https://picsum.photos/600/350??random=4",
      "score": 9.2,
      "intro": "天坛始建于明代，是明清两代皇帝祭祀皇天、祈祷五谷丰登的场所，以严谨的建筑布局、奇特的建筑构造和瑰丽的建筑装饰著称于世。",
      "address": "北京市东城区天坛东里甲1号"
    },
    {
      "id": "5",
      "name": "兵马俑",
      "nameEn": "Terracotta Army",
      "image": "https://picsum.photos/600/350?random=5",
      "score": 9.8,
      "intro": "秦始皇兵马俑是世界十大古墓稀世珍宝之一，气势恢宏，造型逼真，被誉为“世界第八大奇迹”，是中国古代辉煌文明的金字名片。",
      "address": "陕西省西安市临潼区秦陵北路"
    },
    {
      "id": "6",
      "name": "西湖",
      "nameEn": "West Lake",
      "image": "https://picsum.photos/600/350?random=6",
      "score": 9.5,
      "intro": "杭州西湖是中国十大风景名胜之一，三面云山，一水抱城，以秀丽的湖光山色和众多名胜古迹闻名中外，被誉为“人间天堂”。",
      "address": "浙江省杭州市西湖区西湖风景区"
    },
    {
      "id": "7",
      "name": "布达拉宫",
      "nameEn": "Potala Palace",
      "image": "https://picsum.photos/600/350??random=7",
      "score": 9.7,
      "intro": "布达拉宫是世界上海拔最高的宫殿，是藏传佛教的圣地，依山而建，气势雄伟，是西藏最庞大、最完整的古代宫堡建筑群。",
      "address": "西藏自治区拉萨市城关区北京中路35号"
    },
    {
      "id": "8",
      "name": "张家界",
      "nameEn": "Zhangjiajie",
      "image": "https://picsum.photos/600/350?random=8",
      "score": 9.4,
      "intro": "张家界国家森林公园以峰奇、谷幽、水秀、林深著称，被誉为“中国山水画的原本”，是阿凡达悬浮山的取景地。",
      "address": "湖南省张家界市武陵源区金鞭路"
    },
    {
      "id": "9",
      "name": "黄山",
      "nameEn": "Huangshan Mountain",
      "image": "https://picsum.photos/600/350?random=9",
      "score": 9.8,
      "intro": "黄山被誉为“天下第一奇山”，以奇松、怪石、云海、温泉、冬雪“五绝”著称于世，是中国山水文化的杰出代表。",
      "address": "安徽省黄山市黄山区汤口镇"
    }
  ],
